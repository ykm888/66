CONFIG_64BIT=y
CONFIG_ARM64=y
CONFIG_ARCH_MEDIATEK=y
CONFIG_COMMON_CLK_MT7981=y
CONFIG_COMMON_CLK_MT7981_ETHSYS=y
CONFIG_PINCTRL_MT7981=y

# 物理修复：关闭导致 mtk_eth_soc.o 报错的卸载功能
# CONFIG_NET_MEDIATEK_SOC_WED is not set

# 物理剔除：删除所有无关的移动/车载平台配置
# CONFIG_COMMON_CLK_MT2712 is not set
# CONFIG_COMMON_CLK_MT6779 is not set
# CONFIG_COMMON_CLK_MT6795 is not set
# CONFIG_COMMON_CLK_MT6797 is not set
# CONFIG_COMMON_CLK_MT8173 is not set
# CONFIG_COMMON_CLK_MT8183 is not set
# CONFIG_COMMON_CLK_MT8195 is not set
# CONFIG_PINCTRL_MT2712 is not set
# CONFIG_PINCTRL_MT6765 is not set
# CONFIG_PINCTRL_MT8173 is not set

# 核心网络驱动
CONFIG_NET_VENDOR_MEDIATEK=y
CONFIG_NET_MEDIATEK_SOC=y
CONFIG_MEDIATEK_GE_SOC_PHY=y
CONFIG_MTK_NET_PHYLIB=y

# 核心存储驱动 (EMMC/NAND)
CONFIG_MMC_MTK=y
CONFIG_MTD_NAND_MTK=y
CONFIG_MTD_SPI_NAND=y
CONFIG_MTD_SPI_NOR=y
CONFIG_MTD_UBI=y

# 基础系统支持
CONFIG_ARM_GIC_V3=y
CONFIG_ARM_PSCI_FW=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_THERMAL=y
CONFIG_WATCHDOG=y
CONFIG_MEDIATEK_WATCHDOG=y
CONFIG_PCI=y
CONFIG_PCIE_MEDIATEK_GEN3=y
